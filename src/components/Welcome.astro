---
import photo from "../assets/marco.jpg";
---

<div id="container">
  <main>
    <section id="hero">
      <span class="year-label anim">Portfolio — 2026</span>

      <div class="hero-body">
        <div class="hero-left">
          <h1 class="anim anim-delay-1">
            Mark<br />
            <em>Castro</em><br />
            Jr.
          </h1>
          <p class="tagline anim anim-delay-2">
            I always love using AI, not just because I'm lazy, but because it
            makes production faster and less time-consuming.
          </p>
        </div>

        <div class="hero-right anim anim-delay-3">
          <div class="photo-frame">
            <img src={photo.src} alt="Mark Castro Jr." />
          </div>
        </div>
      </div>
    </section>
  </main>

  <div class="deco-circle deco-1 anim anim-delay-4"></div>
  <div class="deco-circle deco-2 anim anim-delay-4"></div>
</div>

<style>
  /* ── Entrance animation ── */
  @keyframes fadeSlideUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeSlideIn {
    from {
      opacity: 0;
      transform: translateX(24px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .anim {
    opacity: 0;
    animation: fadeSlideUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .hero-right.anim {
    animation-name: fadeSlideIn;
  }

  .anim-delay-1 { animation-delay: 0.15s; }
  .anim-delay-2 { animation-delay: 0.3s; }
  .anim-delay-3 { animation-delay: 0.2s; }
  .anim-delay-4 { animation-delay: 0.5s; }

  /* ── Respect reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .anim {
      opacity: 1;
      animation: none;
    }
  }

  /* ── Rest of your existing styles ── */
  #container {
    min-height: calc(100vh - 64px);
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    background: var(--bg);
  }

  main {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #hero {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 48px;
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
  }

  .year-label {
    font-family: ui-monospace, "Cascadia Code", "Source Code Pro", monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--hint);
    margin-bottom: 40px;
    display: block;
  }

  .hero-body {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 80px;
    align-items: center;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
  }

  h1 {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(40px, 8vw, 72px);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin-bottom: 28px;
  }

  h1 em {
    font-style: italic;
    color: var(--muted);
  }

  .tagline {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.7;
    max-width: 420px;
    margin-bottom: 40px;
  }

  .bottom-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    padding-top: 28px;
    border-top: 0.5px solid var(--rule);
  }

  .cta-links {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .btn-primary {
    background: var(--ink);
    color: var(--bg);
    font-size: 13px;
    padding: 10px 22px;
    border-radius: 6px;
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: opacity 0.2s;
  }

  .btn-primary:hover { opacity: 0.8; }

  .btn-secondary {
    font-size: 13px;
    color: var(--muted);
    text-decoration: none;
    border-bottom: 0.5px solid var(--rule);
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;
  }

  .btn-secondary:hover {
    color: var(--ink);
    border-color: var(--muted);
  }

  .availability {
    display: flex;
    align-items: center;
    gap: 7px;
    font-family: ui-monospace, "Cascadia Code", "Source Code Pro", monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--hint);
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #4caf50;
    flex-shrink: 0;
  }

  .hero-right {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .photo-frame {
    width: 100%;
    aspect-ratio: 3 / 4;
    border-radius: 12px;
    overflow: hidden;
    border: 0.5px solid var(--rule);
  }

  .photo-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
  }

  .deco-circle {
    position: absolute;
    border-radius: 50%;
    border: 0.5px solid var(--rule);
    pointer-events: none;
  }

  .deco-1 {
    width: 320px;
    height: 320px;
    top: -80px;
    right: -80px;
  }

  .deco-2 {
    width: 200px;
    height: 200px;
    top: -20px;
    right: -20px;
  }

  @media (max-width: 900px) {
    .hero-body {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .hero-right {
      order: -1;
    }

    .photo-frame {
      aspect-ratio: 4 / 3;
      max-height: 280px;
    }
  }

  @media (max-width: 640px) {
    #hero {
      padding: 32px 24px;
    }

    .bottom-row {
      flex-direction: column;
      align-items: flex-start;
    }

    .deco-circle {
      display: none;
    }
  }
</style>