---
const skillGroups = [
  {
    category: "Design",
    items: ["Canva", "Figma"],
  },
  {
    category: "Front-end",
    items: ["HTML", "CSS", "Bootstrap"],
  },
  {
    category: "Programming",
    items: ["Python"],
  },
  {
    category: "Productivity",
    items: ["Microsoft Word", "Microsoft Excel", "Microsoft PowerPoint", "Microsoft Outlook"],
  },
];
---

<section id="skills">
  <div class="skills-inner">

    <div class="skills-header">
      <span class="section-label anim">Skills</span>
      <h2 class="anim anim-delay-1">Tools &amp; <em>software.</em></h2>
      <p class="subtitle anim anim-delay-2">
        A collection of tools and technologies I work with
        across design, development, and productivity.
      </p>
    </div>

    <div class="skills-grid">
      {skillGroups.map((group, i) => (
        <div class="skill-group anim" style={`animation-delay: ${0.3 + i * 0.1}s`}>
          <span class="group-label">{group.category}</span>
          <ul class="skill-list">
            {group.items.map(item => (
              <li class="skill-item">{item}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  /* ── Entrance animation ── */
  @keyframes fadeSlideUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .anim {
    opacity: 0;
    animation: fadeSlideUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .anim-delay-1 { animation-delay: 0.1s; }
  .anim-delay-2 { animation-delay: 0.2s; }

  /* Each .skill-group gets its delay inline via style prop above */

  @media (prefers-reduced-motion: reduce) {
    .anim {
      opacity: 1;
      animation: none;
    }
  }

  /* ── Existing styles ── */
  #skills {
    min-height: calc(100vh - 64px);
    background: var(--bg);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px 48px;
  }

  .skills-inner {
    width: 100%;
    max-width: 640px;
  }

  .skills-header {
    margin-bottom: 56px;
  }

  .section-label {
    font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--hint);
    display: block;
    margin-bottom: 20px;
  }

  h2 {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(36px, 7vw, 60px);
    font-weight: 400;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin-bottom: 20px;
  }

  h2 em {
    font-style: italic;
    color: var(--muted);
  }

  .subtitle {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.7;
    max-width: 400px;
  }

  .skills-grid {
    display: flex;
    flex-direction: column;
    border-top: 0.5px solid var(--rule);
  }

  .skill-group {
    display: flex;
    align-items: baseline;
    gap: 48px;
    padding: 28px 0;
    border-bottom: 0.5px solid var(--rule);
  }

  .group-label {
    font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', monospace;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--hint);
    min-width: 96px;
    flex-shrink: 0;
  }

  .skill-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .skill-item {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 15px;
    color: var(--ink);
    font-style: italic;
  }

  @media (max-width: 640px) {
    #skills {
      padding: 60px 24px;
    }

    .skill-group {
      flex-direction: column;
      gap: 16px;
    }
  }
</style>